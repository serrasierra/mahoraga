# Used at `npm run build` time only (Vite embeds this into the JS bundle).
# Required for Cloudflare Pages builds AND for local `wrangler pages deploy` after `npm run build`.
# Must be the full Worker URL including https and /agent — e.g. https://mahoraga.your-subdomain.workers.dev/agent
# For local Vite dev (`npm run dev`), leave unset to use the /api proxy to wrangler dev.
VITE_MAHORAGA_API_BASE=https://your-worker-subdomain.workers.dev/agent
